{
  "name": "literally-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:storybook": "storybook build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "npx vitest",
    "test:ci": "npx vitest run --mode test",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "docs:components": "npm run docs:components --workspaces --if-present"
  },
  "devDependencies": {
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@lit/context": "^1.1.6",
    "@open-wc/testing": "^4.0.0",
    "@storybook/web-components": "^10.4.6",
    "@storybook/web-components-vite": "^10.4.6",
    "husky": "^9.0.11",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "lit": "^3.3.3",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "storybook": "^10.4.6",
    "tsx": "^4.23.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "oxfmt",
      "oxlint --fix"
    ]
  },
  "customElements": "custom-elements.json"
}
