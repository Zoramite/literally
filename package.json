{
  "name": "literally-monorepo",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "tsc --build",
    "build:storybook": "storybook build",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "npx vitest",
    "test:ci": "npx vitest run --mode test",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006"
  },
  "devDependencies": {
    "@lit/context": "^1.1.6",
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-essentials": "^8.1.1",
    "@storybook/blocks": "^8.1.1",
    "@storybook/web-components": "^8.1.1",
    "@storybook/web-components-vite": "^8.1.1",
    "husky": "^9.0.11",
    "jsdom": "^29.1.1",
    "lit": "^3.3.3",
    "lint-staged": "^17.0.7",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "storybook": "^8.1.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^5.2.11",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{ts,js}": [
      "oxfmt",
      "oxlint --fix"
    ]
  }
}
