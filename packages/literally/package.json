{
  "name": "@littoral/literally",
  "version": "2.6.0",
  "description": "Lit based structural web components for app development.",
  "exports": {
    "./*": "./src/*.ts"
  },
  "bin": {
    "generate-components-doc": "./bin/generate-components-doc.mjs"
  },
  "scripts": {
    "docs:components": "cem analyze --litelement --globs \"src/**/*.ts\" --exclude \"src/**/*.test.ts\" --exclude \"src/**/*.stories.ts\" && node ./bin/generate-components-doc.mjs"
  },
  "keywords": [
    "lit"
  ],
  "homepage": "https://github.com/Zoramite/literally#readme",
  "bugs": {
    "url": "https://github.com/Zoramite/literally/issues"
  },
  "license": "MIT",
  "author": "Randy Merrill <Zoramite+github@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Zoramite/literally.git"
  },
  "dependencies": {},
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@lit/context": "^1.1.6",
    "lit": "^3.3.3"
  },
  "customElements": "custom-elements.json"
}
